#### **4. Verdict Generation Function**

```python
def get_verdict_for_metric(metric_name: str, score: float) -> str:
    """
    Converts numeric score (0-1) to human-readable verdict
    
    Different metrics have different verdict ranges:
    
    Args:
        metric_name: Which metric was evaluated
        score: Numeric score from 0 to 1
        
    Returns:
        Verdict string based on metric type
    """
    
    # Faithfulness verdicts
    if metric_name == "faithfulness":
        if score >= 0.75:
            return "FAITHFUL"           # ✅ Good
        elif score >= 0.3:
            return "PARTIAL"            # ⚠️  Okay
        else:
            return "NOT_FAITHFUL"       # ❌ Bad
    
    # Answer Relevancy verdicts
    elif metric_name == "answer_relevancy":
        if score >= 0.75:
            return "RELEVANT"           # ✅ Good
        elif score >= 0.3:
            return "PARTIAL"            # ⚠️  Okay
        else:
            return "NOT_RELEVANT"       # ❌ Bad
    
    # Contextual Recall verdicts
    elif metric_name == "contextual_recall":
        if score >= 0.75:
            return "HIGH_RECALL"        # ✅ Good
        elif score >= 0.5:
            return "PARTIAL_RECALL"     # ⚠️  Okay
        else:
            return "LOW_RECALL"         # ❌ Bad
    
    # Contextual Relevancy verdicts
    elif metric_name == "contextual_relevancy":
        if score >= 0.75:
            return "HIGHLY_RELEVANT"    # ✅ Good
        elif score >= 0.5:
            return "PARTIALLY_RELEVANT" # ⚠️  Okay
        else:
            return "LOW_RELEVANCY"      # ❌ Bad
    
    # ... more metrics ...
```

