#### **2. MetricEvaluator Class** - Main Evaluation Engine

```python
class MetricEvaluator:
    """
    Handles all metric evaluations using DeepEval
    """
    
    SUPPORTED_METRICS = {
        "faithfulness": "Evaluates if output is faithful to context",
        "contextual_precision": "Evaluates if context is relevant",
        "contextual_recall": "Evaluates if context contains all needed info",
        "contextual_relevancy": "Evaluates how relevant output is to query",
        "answer_relevancy": "Evaluates if output answers the query",
        "pii_leakage": "Detects personally identifiable information",
        "bias": "Detects bias in output",
        "hallucination": "Detects if output contains false information",
    }
    
    def __init__(self, api_key: str, model_name: str = "llama-3.3-70b-versatile"):
        """
        Initialize evaluator with LLM for evaluation
        
        Args:
            api_key: API key for LLM service (Groq or OpenAI)
            model_name: Which LLM to use for evaluation
        """
        if not api_key:
            raise ValueError("Valid API key is required")
        
        self.model_name = model_name
        # Create LLM instance (Groq or OpenAI)
        self.model = GroqModel(api_key=api_key, model=model_name)
    
    def evaluate(self, metric_name: str, params) -> tuple[float, str]:
        """
        Main evaluation dispatcher
        Routes to correct metric function based on metric_name
        
        Args:
            metric_name: Which metric to use
            params: Query, output, context, etc.
            
        Returns:
            Tuple of (score, explanation)
        """
        
        # Create test case from parameters
        test_case = self.create_test_case(
            query=params.get('query'),
            context=params.get('context'),
            output=params.get('output'),
            expected_output=params.get('expected_output')
        )
        
        # Route to correct metric function
        if metric_name == "faithfulness":
            return self.evaluate_faithfulness(test_case)
        elif metric_name == "answer_relevancy":
            return self.evaluate_answer_relevancy(test_case)
        elif metric_name == "contextual_recall":
            return self.evaluate_contextual_recall(test_case)
        elif metric_name == "contextual_relevancy":
            return self.evaluate_contextual_relevancy(test_case)
        # ... more metrics ...
        else:
            raise ValueError(f"Metric {metric_name} not implemented")
