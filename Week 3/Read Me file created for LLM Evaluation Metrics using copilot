#### **5. Main API Endpoint**

```python
@app.post("/eval")
async def evaluate(request: EvalRequest) -> EvalResponse:
    """
    Main evaluation endpoint
    
    Receives evaluation request and returns results
    
    Input (EvalRequest):
    {
        "metric": "faithfulness",
        "query": "What is AI?",
        "output": "AI is...",
        "context": ["AI definition..."],
        "expected_output": null,
        "provider": "groq"
    }
    
    Output (EvalResponse):
    {
        "results": [{
            "metric_name": "faithfulness",
            "score": 0.92,
            "verdict": "FAITHFUL",
            "explanation": "..."
        }]
    }
    """
    
    try:
        # Determine which evaluator to use (Groq or OpenAI)
        evaluator = init_evaluator_from_env()
        
        # Evaluate
        score, explanation = evaluator.evaluate(
            metric_name=request.metric,
            params={
                'query': request.query,
                'output': request.output,
                'context': request.context,
                'expected_output': request.expected_output
            }
        )
        
        # Get verdict from score
        verdict = get_verdict_for_metric(request.metric, score)
        
        # Return response
        return EvalResponse(
            results=[
                MetricResult(
                    metric_name=request.metric,
                    score=score,
                    verdict=verdict,
                    explanation=explanation
                )
            ]
        )
        
    except Exception as e:
        # Error handling
        return EvalResponse(
            results=[
                MetricResult(
                    metric_name=request.metric,
                    error=str(e)
                )
            ]
        )
```

**Why it matters:** Handles actual evaluation using DeepEval

