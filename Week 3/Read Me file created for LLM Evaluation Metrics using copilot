#### **2. evalRoutes.ts** - Main Evaluation Endpoint

```typescript
/**
 * POST /api/eval-only
 * 
 * Main endpoint for evaluation requests
 * 
 * REQUEST BODY:
 * {
 *   metric?: string,              // Default: "answer_relevancy"
 *   query: string,                // User's question
 *   output: string,               // LLM's response (not always required)
 *   context?: string | string[],  // Background documents
 *   expected_output?: string,     // Reference answer (for contextual metrics)
 *   provider?: string             // "groq" or "openai" (default: "groq")
 * }
 */
router.post('/eval-only', asyncHandler(async (req: Request, res: Response) => {
  /**
   * Step 1: Extract request body
   */
  const { query, output, context, metric, expected_output } = req.body;
  
  /**
   * Step 2: Determine effective metric (default if not provided)
   */
  const effectiveMetric = metric || "answer_relevancy";
  
  /**
   * Step 3: VALIDATION - Check metric-specific requirements
   * 
   * Different metrics have different requirements:
   * - faithfulness: needs query + output + context
   * - answer_relevancy: needs query + output
   * - contextual_precision: needs query + context + expected_output
   * - contextual_recall: needs context + expected_output
   * - contextual_relevancy: needs query + output
   * - pii_leakage: needs query + output
   * - bias: needs query + output
   * - hallucination: needs query + output + context
   */
  
  // Metrics that DON'T require output field:
  const metricsNotRequiringOutput = [
    'contextual_precision',
    'contextual_recall'
  ];
  
  // Validate required fields exist
  if (!metricsNotRequiringOutput.includes(effectiveMetric) && !output) {
    return res.status(400).json({
      error: "Missing required field: output"
    });
  }
  
  // Validate metric-specific requirements
  if (effectiveMetric === 'pii_leakage' && !query) {
    return res.status(400).json({
      error: "Missing required field: query (required for pii_leakage metric)"
    });
  }
  
  // ... more validation for other metrics ...
  
  /**
   * Step 4: BUILD PAYLOAD for Python service
   */
  const evalParams = {
    metric: effectiveMetric,
    provider: req.body.provider || "groq",
    output: output,
    query: query,
    context: Array.isArray(context) ? context : (context ? [context] : []),
    expected_output: expected_output
  };
  
  /**
   * Step 5: CALL Python service
   */
  const result = await evalWithFields(evalParams);
  
  /**
   * Step 6: RETURN response to frontend
   */
  return res.json({
    metric: effectiveMetric,
    score: result.score,
    verdict: result.verdict,
    explanation: result.explanation,
    query: query,
    output: output,
    context: Array.isArray(context) ? context : (context ? [context] : [])
  });
}));
```

**Response Status Codes:**
- `200 OK` - Successful evaluation
- `400 Bad Request` - Missing required fields or invalid input
- `500 Internal Server Error` - Backend or Python service error

**Why it matters:** Gateway for all evaluation requests

