#### **3. Individual Metric Functions**

```python
def evaluate_faithfulness(self, test_case) -> tuple[float, str]:
    """
    Evaluates if LLM output is faithful to provided context
    
    What it does:
    1. Extracts claims/facts from output
    2. Checks each claim against context
    3. Returns: faithful/not_faithful/idk for each claim
    4. Calculates overall faithfulness score
    
    strict_mode=False: Natural LLM judgment (not strict rules)
    include_reason=True: Include detailed explanation
    
    Returns:
        score: 0-1 (higher = more faithful)
        explanation: Why it's faithful/not faithful
    """
    from deepeval.metrics.faithfulness.faithfulness import FaithfulnessMetric
    
    # Validate required fields
    if not test_case.input:
        raise ValueError("faithfulness requires 'query' field")
    if not test_case.actual_output:
        raise ValueError("faithfulness requires 'output' field")
    if not test_case.retrieval_context:
        raise ValueError("faithfulness requires 'context' field")
    
    # Create metric instance
    metric = FaithfulnessMetric(
        model=self.model,              # Use the evaluator LLM
        include_reason=True,           # Include detailed explanation
        async_mode=False,              # Synchronous (wait for result)
        strict_mode=False              # Natural judgment
    )
    
    # Measure the test case
    score = metric.measure(test_case)  # Returns 0-1
    explanation = metric.reason or "Default explanation"
    
    return score, explanation  # (0.92, "Output is faithful to context")
```

```python
def evaluate_contextual_relevancy(self, test_case) -> tuple[float, str]:
    """
    Evaluates how relevant the output is to the query
    
    What it does:
    1. Takes query and output
    2. Judges how well output addresses query
    3. Returns relevancy score
    
    Returns:
        score: 0-1 (higher = more relevant)
        explanation: Why output is/isn't relevant to query
    """
    from deepeval.metrics.answer_relevancy.answer_relevancy import AnswerRelevancyMetric
    
    # Validate required fields
    if not test_case.input:
        raise ValueError("contextual_relevancy requires 'query' field")
    if not test_case.actual_output:
        raise ValueError("contextual_relevancy requires 'output' field")
    
    # Create metric instance (using AnswerRelevancyMetric)
    metric = AnswerRelevancyMetric(
        model=self.model,
        include_reason=True,
        async_mode=False,
        strict_mode=False
    )
    
    # Measure the test case
    score = metric.measure(test_case)
    explanation = metric.reason or "Output relevance evaluation"
    
    return score, explanation
```

