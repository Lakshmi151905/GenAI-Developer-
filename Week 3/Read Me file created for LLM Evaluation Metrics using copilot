#### **3. evalClient.ts** - Python Service Communication

```typescript
/**
 * Communicates with Python DeepEval service
 * Acts as the "courier" between backend and Python
 */

export async function evalWithFields(params: {
  query?: string;
  context?: string[];
  output?: string;
  expected_output?: string;
  metric?: string;
  provider?: string;
}): Promise<EvalResult> {
  
  /**
   * Step 1: VALIDATION (safety check)
   * Make sure output is provided unless metric doesn't need it
   */
  const metricsNotRequiringOutput = [
    'contextual_precision',
    'contextual_recall'
  ];
  
  if (!metricsNotRequiringOutput.includes(params.metric!) && !params.output) {
    throw new Error("output field is required");
  }
  
  /**
   * Step 2: BUILD PAYLOAD for Python service
   * Include only fields that are provided
   */
  const payload: any = {
    metric: params.metric || "faithfulness",
  };
  
  // Add optional fields
  if (params.output) payload.output = params.output;
  if (params.query) payload.query = params.query;
  if (params.context) payload.context = params.context;
  if (params.expected_output) payload.expected_output = params.expected_output;
  if (params.provider) payload.provider = params.provider;
  
  /**
   * Step 3: MAKE HTTP REQUEST to Python service
   * URL: http://localhost:8000/eval
   * Method: POST
   * Body: JSON payload
   */
  console.log(`evalWithFields - Sending payload:`, 
    JSON.stringify(payload, null, 2));
  
  try {
    const res = await axios.post<EvalResult>(
      ENV.DEEPEVAL_URL,  // http://localhost:8000/eval
      payload
    );
    
    return res.data;  // {metric_name, score, verdict, explanation}
    
  } catch (err: unknown) {
    // ERROR HANDLING
    if (axios.isAxiosError(err)) {
      
      // Connection refused (Python service not running)
      if ((err as any).code === "ECONNREFUSED") {
        throw new Error(
          `DeepEval service unavailable at ${ENV.DEEPEVAL_URL}. Is it running?`
        );
      }
      
      // Python service returned error
      const errorDetail = err.response?.data?.detail || err.message;
      throw new Error(
        `DeepEval Error (${err.response?.status || 'unknown'}): ${errorDetail}`
      );
    }
    
    throw err;
  }
}
```

**Why it matters:** Bridges backend and Python service

